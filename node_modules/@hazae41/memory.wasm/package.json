{
  "type": "module",
  "name": "@hazae41/memory.wasm",
  "version": "1.0.37",
  "description": "Zero-copy memory for WebAssembly",
  "repository": "github:hazae41/memory.wasm",
  "author": "hazae41",
  "scripts": {
    "compile": "docker compose up --build --exit-code-from app && deno -RW ./patch.wasm.ts",
    "prepare": "rm -rf ./out && tsc && cp -r ./src/wasm/. ./out/wasm && tscousin && deno -RW ./patch.node.ts",
    "version": "deno -RW ./vsync.ts && git add deno.json"
  },
  "files": [
    "./out"
  ],
  "exports": {
    ".": {
      "types": "./out/node/mod.d.ts",
      "import": "./out/node/mod.js"
    }
  },
  "keywords": [
    "reproducible",
    "webassembly",
    "memory",
    "bytes",
    "reference",
    "box",
    "browser",
    "typescript",
    "rust",
    "unit-tested",
    "deno"
  ],
  "devDependencies": {
    "@hazae41/tscousin": "^1.0.9",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  }
}
